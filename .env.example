# Copy this file to .env and add a newly rotated API key locally.
# Never commit .env or paste API keys into the frontend.
PORT=8787
RPIRAQ_API_URL=https://api.rpiraq.com/api/scan
# The supplied sample uses GET with a JSON body. This proxy supports it.
RPIRAQ_API_METHOD=GET
RPIRAQ_API_ACCESS_KEY=PASTE_A_ROTATED_KEY_HERE
# Update these paths after confirming a masked API response.
RPIRAQ_PHONE_FIELD=phone
RPIRAQ_LOCATION_FIELD=location
